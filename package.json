{
  "name": "dad-joke-ext",
  "description": "A minimal New Tab extension that greets you with a fresh dad joke from icanhazdadjoke.com.",
  "version": "2.0.0",
  "type": "module",
  "private": true,
  "author": "Amir Douzandeh (https://github.com/amirzenoozi)",
  "license": "AGPL-3.0-or-later",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "zip:edge": "wxt zip -b edge",
    "package": "wxt zip && wxt zip -b firefox && wxt zip -b edge",
    "compile": "tsc --noEmit",
    "submit:chrome": "wxt submit --chrome-zip .output/*-chrome.zip",
    "submit:firefox": "wxt submit --firefox-zip .output/*-firefox.zip --firefox-sources-zip .output/*-sources.zip",
    "submit:edge": "wxt submit --edge-zip .output/*-edge.zip",
    "postinstall": "wxt prepare"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "wxt": "^0.20.26"
  },
  "dependencies": {
    "html-to-image": "^1.11.11"
  }
}
